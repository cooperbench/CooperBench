diff --git a/dspy/utils/usage_tracker.py b/dspy/utils/usage_tracker.py
index 5199f3ad..ff46db72 100644
--- a/dspy/utils/usage_tracker.py
+++ b/dspy/utils/usage_tracker.py
@@ -60,6 +60,35 @@ class UsageTracker:
         return total_usage_by_lm
 
 
+class CacheUsageTracker:
+    """Tracks cache usage data within a context."""
+
+    def __init__(self):
+        # Track cache events for this specific call
+        self.cache_usage = {
+            'hits': 0,
+            'mem_hits': 0,
+            'disk_hits': 0,
+            'misses': 0
+        }
+
+    def add_cache_hit(self, hit_type: str):
+        """Add a cache hit event."""
+        self.cache_usage['hits'] += 1
+        if hit_type == 'memory':
+            self.cache_usage['mem_hits'] += 1
+        elif hit_type == 'disk':
+            self.cache_usage['disk_hits'] += 1
+
+    def add_cache_miss(self):
+        """Add a cache miss event."""
+        self.cache_usage['misses'] += 1
+
+    def get_cache_usage(self) -> dict[str, int]:
+        """Get the current cache usage data."""
+        return dict(self.cache_usage)
+
+
 @contextmanager
 def track_usage():
     """Context manager for tracking LM usage."""
@@ -67,3 +96,12 @@ def track_usage():
 
     with settings.context(usage_tracker=tracker):
         yield tracker
+
+
+@contextmanager
+def track_cache_usage():
+    """Context manager for tracking cache usage."""
+    tracker = CacheUsageTracker()
+
+    with settings.context(cache_usage_tracker=tracker):
+        yield tracker
