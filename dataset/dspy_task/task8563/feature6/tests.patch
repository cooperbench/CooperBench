+# Test cases for validate_input method - directly matching feature specifications
+def test_validate_input_with_plain_dict():
+    """Test validate_input with plain dictionary input (no code fences)."""
+    data = {"name": "search", "args": {"query": "stanford"}}
+    result = ToolCalls.validate_input(data)
+    assert result == data
+
+
+def test_validate_input_with_plain_list():
+    """Test validate_input with plain list input (no code fences)."""
+    data = [{"name": "search", "args": {"query": "stanford"}}]
+    result = ToolCalls.validate_input(data)
+    assert result == data
+
+
+def test_validate_input_with_json_string():
+    """Test validate_input with plain JSON string (no code fences)."""
+    data = '{"name": "search", "args": {"query": "stanford"}}'
+    result = ToolCalls.validate_input(data)
+    assert result == {"name": "search", "args": {"query": "stanford"}}
+
