+        """Set the process priority for the given PID.
+ 
+        :param pid: Process ID to set priority for
+        :param priority: Priority level ('low', 'below_normal', 'normal', 'above_normal', 'high')
+        """
+        try:
+            if WIN:
+                self._set_windows_priority(pid, priority)
+            else:
