+    def _set_windows_priority(self, pid: int, priority: str) -> None:
+        """Set process priority on Windows."""
+        import subprocess
+ 
+        priority_map = {
+            'low': 'IDLE',
+            'below_normal': 'BELOWNORMAL',
+            'normal': 'NORMAL',
+            'above_normal': 'ABOVENORMAL',
+            'high': 'HIGH'
+        }
+ 
+        if priority not in priority_map:
+            return
+ 
+        try:
+            subprocess.run([
+                'wmic', 'process', 'where', f'ProcessId={pid}',
+                'CALL', 'setpriority', priority_map[priority]
+            ], check=False, capture_output=True)
+        except Exception:
+            pass
+
+    def _set_unix_priority(self, pid: int, priority: str) -> None:
+        """Set process priority on Unix-like systems."""
+        import subprocess
+ 
+        priority_map = {
+            'low': 19,
+            'below_normal': 10,
+            'normal': 0,
+            'above_normal': -10,
+            'high': -20
+        }
+ 
+        if priority not in priority_map:
+            return
+ 
+        try:
+            subprocess.run([
+                'renice', str(priority_map[priority]), str(pid)
+            ], check=False, capture_output=True)
+        except Exception:
+            pass
